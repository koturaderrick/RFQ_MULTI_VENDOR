<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form view -->
    <record id="view_purchase_request_form" model="ir.ui.view">
        <field name="name">purchase.request.form</field>
        <field name="model">purchase.request</field>
        <field name="arch" type="xml">
            <form string="Purchase Request">
                <header>
                    <button name="action_submit" string="Submit to Procurement"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve"
                            type="object" class="btn-success"
                            groups="purchase.group_purchase_manager"
                            invisible="state != 'submitted'"/>
                    <button name="action_reject" string="Reject"
                            type="object" class="btn-danger"
                            groups="purchase.group_purchase_manager"
                            invisible="state != 'submitted'"/>
                    <button name="action_create_rfq" string="Create RFQ"
                            type="object" class="btn-primary"
                            groups="purchase.group_purchase_manager"
                            invisible="state != 'approved'"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ('rejected',)"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,rfq_created"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_rfqs" type="object"
                                class="oe_stat_button" icon="fa-file-text-o"
                                invisible="rfq_count == 0">
                            <field name="rfq_count" widget="statinfo" string="RFQs"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="requested_by"/>
                            <field name="date_request"/>
                            <field name="date_required"/>
                        </group>
                    </group>
                    <group string="Justification">
                        <field name="description" nolabel="1"
                               placeholder="What do you need and why?"/>
                    </group>
                    <!-- only show the vendors section once the request is submitted -->
                    <group string="Vendors to Invite"
                           groups="purchase.group_purchase_user"
                           invisible="state == 'draft'">
                        <field name="vendor_ids"
                               nolabel="1"
                               widget="many2many_tags"
                               options="{'no_create': True}"
                               placeholder="Select vendors to receive an RFQ..."
                               readonly="state in ('rfq_created', 'rejected')"/>
                    </group>
                    <notebook>
                        <page string="Requested Items">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="uom_id"/>
                                    <field name="estimated_price"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List view -->
    <record id="view_purchase_request_list" model="ir.ui.view">
        <field name="name">purchase.request.list</field>
        <field name="model">purchase.request</field>
        <field name="arch" type="xml">
            <list string="Purchase Requests"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'submitted'"
                  decoration-success="state in ('approved','rfq_created')"
                  decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="requested_by"/>
                <field name="date_request"/>
                <field name="date_required"/>
                <field name="rfq_count"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'submitted'"
                       decoration-success="state in ('approved','rfq_created')"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_purchase_request_all" model="ir.actions.act_window">
        <field name="name">Purchase Requests</field>
        <field name="res_model">purchase.request</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_purchase_request_mine" model="ir.actions.act_window">
        <field name="name">My Purchase Requests</field>
        <field name="res_model">purchase.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('requested_by', '=', uid)]</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_purchase_request_root"
              name="Purchase Requests"
              parent="purchase.menu_purchase_root"
              sequence="5"/>

    <menuitem id="menu_my_purchase_request"
              name="My Requests"
              parent="menu_purchase_request_root"
              action="action_purchase_request_mine"
              sequence="10"/>

    <menuitem id="menu_all_purchase_request"
              name="All Requests"
              parent="menu_purchase_request_root"
              action="action_purchase_request_all"
              groups="purchase.group_purchase_user"
              sequence="20"/>

</odoo>
